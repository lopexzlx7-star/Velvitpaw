modules = ["nodejs-20", "bash", "web", "nix"]
[agent]
expertMode = true

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3002

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[nix]
channel = "stable-25_05"
packages = ["ffmpeg"]

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "NODE_ENV=production tsx server.ts"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
STORJ_ENDPOINT = "https://gateway.storjshare.io"
STORJ_PUBLIC_BASE_URL = "https://link.storjshare.io/raw/jxyuu7jm36enzvozprfsbhiz2i4a/Velvitpaw"
CLOUDINARY_CLOUD_NAME = "dekidzsq6"
CLOUDINARY_UPLOAD_PRESET = "velvitpaw_uploads"

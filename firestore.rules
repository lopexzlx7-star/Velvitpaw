rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'createdAt', 'uid']) &&
             data.keys().hasOnly(['username', 'createdAt', 'uid', 'lastLogin', 'profilePhotoUrl', 'recoveryEmail', 'accentColor', 'bio']) &&
             data.username is string && 
             data.username.size() >= 3 && 
             data.username.size() <= 20 &&
             data.username.matches("^[a-zA-Z0-9_]+$") &&
             data.uid == request.auth.uid;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['url', 'title', 'type', 'height', 'authorUid', 'authorName', 'createdAt']) &&
             data.url is string && data.url.size() < 1000000 &&
             data.title is string && data.title.size() <= 100 &&
             data.type in ['image', 'gif', 'video'] &&
             data.height is number &&
             data.authorUid == request.auth.uid &&
             data.authorName is string &&
             data.createdAt is string;
    }

    function isValidFollowing(data) {
      return data.keys().hasAll(['followerUid', 'followingUid', 'createdAt']) &&
             data.followerUid == request.auth.uid &&
             data.followingUid is string &&
             data.createdAt is string;
    }

    function isValidInteraction(data) {
      return data.keys().hasAll(['uid', 'postId', 'type', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.postId is string &&
             data.type in ['like', 'save', 'view'] &&
             data.createdAt is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'message', 'read', 'createdAt']) &&
             data.userId is string &&
             data.type in ['like_group', 'trending', 'new_post', 'new_follower', 'recommended', 'like', 'comment'] &&
             data.message is string &&
             data.read is bool &&
             data.createdAt is string;
    }

    match /users/{username} {
      allow get: if true;
      allow list: if true;
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && username == request.resource.data.username;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && (
        isValidUser(request.resource.data) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['verifiedPhone', 'phoneVerifiedAt'])
      );
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
    
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        (resource.data.authorUid == request.auth.uid && isValidPost(request.resource.data)) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'savesCount', 'viewsCount'])
      );
    }

    match /following/{followId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidFollowing(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.followerUid == request.auth.uid;
    }

    match /interactions/{interactionId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidInteraction(request.resource.data);
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && isValidInteraction(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /folders/{folderId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /userKeys/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated() && (
        resource.data.isPublic == true || request.auth.uid in resource.data.members
      );
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.adminUid == request.auth.uid && request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated() && (
        resource.data.adminUid == request.auth.uid ||
        (request.auth.uid in resource.data.members && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'members']))
      );
      allow delete: if isAuthenticated() && resource.data.adminUid == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members && request.resource.data.senderId == request.auth.uid;
      }
    }

    match /calls/{callId} {
      allow read: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.callerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);

      match /callerCandidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
      match /calleeCandidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
